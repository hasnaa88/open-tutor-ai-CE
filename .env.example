# Application Environment
# DEBUG=true bypasses the SECRET_KEY strength check — safe for local dev, never for production.
ENV=dev
DEBUG=true
GLOBAL_LOG_LEVEL=INFO

# Application Build
TUTORAI_BUILD_HASH=dev-build

# Ollama URL for the backend to connect
# Proxied via /api/v1/providers/ollama/* — use http://ollama:11434 inside Docker Compose
OLLAMA_BASE_URL=http://localhost:11434

# CORS Configuration
CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173

# OpenAI Configuration
OPENAI_API_BASE_URL=
OPENAI_API_KEY=

# Gemini Configuration
GEMINI_API_KEY=

# Database Configuration
DATABASE_URL=sqlite:///./var/tutorai.db

# Authentication Configuration
# PRODUCTION: set DEBUG=false and replace SECRET_KEY with a random value:
#   openssl rand -hex 32
# With DEBUG=false, the app refuses to start if this placeholder is used.
SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# File Upload Configuration
UPLOAD_DIR=./var/uploads
MAX_UPLOAD_SIZE_MB=100

# Vector Database / RAG Configuration
VECTOR_DB_PATH=./var/vector_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Audio (TTS/STT) Configuration
# Set via Admin > Settings > Audio in the UI. Leave empty to disable.
AUDIO_TTS_ENGINE=
AUDIO_STT_ENGINE=

# Image Generation Configuration
# Set via Admin > Settings > Images in the UI. Leave empty to disable.
IMAGES_ENGINE=

# Analytics and Telemetry
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

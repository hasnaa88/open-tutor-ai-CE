{
	"name": "open-tutorai",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "npm run pyodide:fetch && vite dev --host",
		"dev:5050": "npm run pyodide:fetch && vite dev --port 5050",
		"build": "npm run pyodide:fetch && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "npm run lint:frontend ; npm run lint:types",
		"lint:frontend": "eslint . --fix",
		"lint:types": "npm run check",
		"format": "prettier --plugin-search-dir --write \"**/*.{js,ts,svelte,css,md,html,json}\"",
		"i18n:parse": "i18next --config i18next-parser.config.ts && prettier --write \"src/lib/i18n/**/*.{js,json}\"",
		"cy:open": "cypress open",
		"test:frontend": "vitest --passWithNoTests",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"pyodide:fetch": "node scripts/prepare-pyodide.js"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "3.2.2",
		"@sveltejs/adapter-static": "^3.0.2",
		"@sveltejs/kit": "^2.64.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/postcss": "^4.0.0",
		"@tailwindcss/typography": "^0.5.13",
		"@testing-library/svelte": "^4.0.5",
		"@types/three": "^0.174.0",
		"@typescript-eslint/eslint-plugin": "^6.17.0",
		"@typescript-eslint/parser": "^6.17.0",
		"cypress": "^15.17.0",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-cypress": "^3.4.0",
		"eslint-plugin-svelte": "^2.43.0",
		"i18next-parser": "^9.0.1",
		"jsdom": "^24.1.3",
		"postcss": "^8.5.15",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.6",
		"sass-embedded": "^1.81.0",
		"svelte": "^5.56.3",
		"svelte-check": "^3.8.5",
		"svelte-confetti": "^2.3.2",
		"tailwindcss": "^4.0.0",
		"tslib": "^2.4.1",
		"typescript": "^5.5.4",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.8"
